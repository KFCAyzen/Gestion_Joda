{
  "name": "gestion_joda",
  "version": "0.1.0",
  "description": "Joda Company — Gestion des bourses d'études en Chine (application desktop)",
  "author": "Joda Company <contact@joda.company>",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report tests/.report",
    "test:all": "powershell -ExecutionPolicy Bypass -File tests/run-all-tests.ps1",
    "electron:build-main": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run electron:build-main && cross-env ELECTRON_DEV_URL=http://localhost:3000 electron dist-electron/main.js",
    "electron:start": "npm run electron:build-main && electron dist-electron/main.js",
    "desktop:build": "cross-env NEXT_BUILD_STANDALONE=1 next build && npm run electron:build-main",
    "desktop:dist": "npm run desktop:build && electron-builder --win nsis",
    "desktop:dist:dir": "npm run desktop:build && electron-builder --win nsis --dir"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.96.2",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.7.0",
    "next": "^16.2.6",
    "next-intl": "^4.11.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.0",
    "resend": "^6.12.2",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.2",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
