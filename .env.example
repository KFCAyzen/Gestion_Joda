# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Uniquement côté serveur / scripts

# IMPORTANT (Vercel) : scoper ces variables à TOUS les environnements
# (Production + Preview + Development). Si elles ne sont pas dans Preview,
# le build des déploiements de branche échoue avec "supabaseUrl is required".

# Email (Resend)
RESEND_API_KEY=re_...

# Cron (protège /api/cron/*)
CRON_SECRET=...

# SMS
SMS_API_USER=...
SMS_API_PASSWORD=...
SMS_SENDER_ID=...
SMS_DLR_SECRET=...

# Newsletter (optionnel — défaut applicatif si absent)
NEWSLETTER_INACTIVITY_DAYS=30
